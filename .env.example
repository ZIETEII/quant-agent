# ─────────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE BASE DE DATOS MÁSTER
# ─────────────────────────────────────────────────────────────────
# Supabase PostgreSQL Transaction Pool Connection
DATABASE_URL=postgresql://[USERNAME]:[PASSWORD]@[HOST]:5432/postgres

# ─────────────────────────────────────────────────────────────────
# CREDENCIALES SOLANA BLOCKCHAIN
# ─────────────────────────────────────────────────────────────────
# Llave privada de la wallet administradora en Base58 (Evita exponer este archivo)
SOLANA_PRIVATE_KEY=tu_llave_privada_base58_aqui_xxxxxxxxx

# Instancia Helius RPC / Quicknode Privada 
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=TU_API_KEY_AQUI

# ─────────────────────────────────────────────────────────────────
# SEGURIDAD WEB / FASTAPI BASIC AUTH
# ─────────────────────────────────────────────────────────────────
# Credenciales quemadas de Dashboard (HTTP-Basic)
WEB_USER=admin
WEB_PASS=tu_contraseña_super_segura

# ─────────────────────────────────────────────────────────────────
# INTEGRACIONES DE NOTIFICACIONES (OPCIONAL)
# ─────────────────────────────────────────────────────────────────
# Bot Token de Telegram
TELEGRAM_BOT_TOKEN=tu_token_aqui
TELEGRAM_CHAT_ID=-100000000000
